#!/bin/bash
#
# Fuehrt alle Jupyter Notebooks als Python-Scripts aus.
# Generiert von Ansible - nicht manuell bearbeiten!
#

set -o pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

PASS=0
FAIL=0

# Environment
export JAVA_HOME={{ java_home }}
export SPARK_HOME={{ spark_home }}
export PYSPARK_PYTHON=/usr/bin/python3
export PYSPARK_DRIVER_PYTHON={{ jupyter_home }}/venv/bin/python
export MPLBACKEND=Agg
export PATH={{ jupyter_home }}/venv/bin:$PATH

SCRIPTS_DIR={{ jupyter_data }}/scripts

run_notebook() {
    local script="$1"
    local name
    name=$(basename "$script" .py)

    echo -n "  "
    if {{ jupyter_home }}/venv/bin/python "$script" > /tmp/notebook_${name}.log 2>&1; then
        echo -e "${GREEN}✓${NC} $name"
        ((PASS++))
    else
        echo -e "${RED}✗${NC} $name"
        echo -e "    ${YELLOW}Log: /tmp/notebook_${name}.log${NC}"
        tail -5 /tmp/notebook_${name}.log | sed 's/^/    /'
        ((FAIL++))
    fi
}

echo "=== Notebook Integration Tests ==="
echo ""

for script in "$SCRIPTS_DIR"/[0-9][0-9]-*.py; do
    [ -f "$script" ] || continue
    run_notebook "$script"
done

echo ""
echo "========================================="
echo -e "Ergebnis: ${GREEN}$PASS bestanden${NC}, ${RED}$FAIL fehlgeschlagen${NC}"
echo "========================================="

[[ $FAIL -eq 0 ]]
