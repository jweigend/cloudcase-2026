   "source": [
    "# NYC Taxi Data Analysis - ClickHouse OLAP\n",
    "\n",
    "Dieses Notebook demonstriert **spaltenorientierte OLAP-Analyse** mit ClickHouse.\n",
    "\n",
    "## Architektur\n",
    "\n",
    "```\n",
    "                        node0\n",
    "                    +-------------+\n",
    "                    |  JupyterLab |\n",
    "                    | (clickhouse |\n",
    "                    |  -connect)  |\n",
    "                    +------+------+\n",
    "                           | HTTP :8123\n",
    "        +------------------+------------------+\n",
    "        |                  |                  |\n",
    "+-------+-------+ +-------+-------+ +--------+------+ +-------------+\n",
    "|     node1     | |     node2     | |     node3     | |    node4    |\n",
    "|  CH Server    | |  CH Server    | |  CH Server    | |  CH Server  |\n",
    "|  CH Keeper    | |  CH Keeper    | |  CH Keeper    | |             |\n",
    "+---------------+ +---------------+ +---------------+ +-------------+\n",
    "```\n",
    "\n",
    "**Datenquelle:** [NYC Taxi & Limousine Commission](https://www.nyc.gov/site/tlc/about/tlc-trip-record-data.page)\n",
    "\n",
    "**Cluster:** `cloudkoffer` (1 Shard, 4 Replicas, ReplicatedMergeTree)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import clickhouse_connect\n",
    "import time\n",
    "\n",
    "# Verbinde mit ClickHouse Cluster\n",
    "client = clickhouse_connect.get_client(\n",
    "    host='node1.{{ domain }}',\n",
    "    port={{ clickhouse_http_port | default(8123) }},\n",
    "    username='default',\n",
    "    password=''\n",
    ")\n",
    "\n",
    "# Cluster-Info\n",
    "version = client.command('SELECT version()')\n",
    "node_count = client.command(\n",
    "    \"SELECT count() FROM system.clusters WHERE cluster = 'cloudkoffer'\"\n",
    ")\n",
    "\n",
    "print('=' * 60)\n",
    "print('CLICKHOUSE CLUSTER INFO')\n",
    "print('=' * 60)\n",
    "print(f'Version:         {version}')\n",
    "print(f'Cluster Nodes:   {node_count}')\n",
    "print(f'Verbunden mit:   node1.{{ domain }}:{{ clickhouse_http_port | default(8123) }}')\n",
    "print('=' * 60)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ReplicatedMergeTree-Tabelle auf allen Nodes erstellen\n",
    "print('Erstelle Tabelle nyc_taxi auf dem Cluster...')\n",
    "\n",
    "client.command(\"\"\"\n",
    "    CREATE TABLE IF NOT EXISTS nyc_taxi ON CLUSTER cloudkoffer\n",
    "    (\n",
    "        VendorID              UInt8,\n",
    "        tpep_pickup_datetime  DateTime,\n",
    "        tpep_dropoff_datetime DateTime,\n",
    "        passenger_count       UInt8,\n",
    "        trip_distance         Float64,\n",
    "        RatecodeID            UInt8,\n",
    "        store_and_fwd_flag    String,\n",
    "        PULocationID          UInt16,\n",
    "        DOLocationID          UInt16,\n",
    "        payment_type          UInt8,\n",
    "        fare_amount           Float64,\n",
    "        extra                 Float64,\n",
    "        mta_tax               Float64,\n",
    "        tip_amount            Float64,\n",
    "        tolls_amount          Float64,\n",
    "        improvement_surcharge Float64,\n",
    "        total_amount          Float64,\n",
    "        congestion_surcharge  Float64,\n",
    "        airport_fee           Float64\n",
    "    )\n",
    "    ENGINE = ReplicatedMergeTree('/clickhouse/tables/{shard}/nyc_taxi', '{replica}')\n",
    "    PARTITION BY toYYYYMM(tpep_pickup_datetime)\n",
    "    ORDER BY (tpep_pickup_datetime, PULocationID)\n",
    "    SETTINGS index_granularity = 8192\n",
    "\"\"\")\n",
    "\n",
    "print('Tabelle nyc_taxi erstellt (ReplicatedMergeTree, partitioniert nach Monat)')\n",
    "\n",
    "# Materialized View VOR dem Datenimport erstellen,\n",
    "# damit sie sich beim INSERT automatisch fuellt.\n",
    "client.command(\"\"\"\n",
    "    CREATE MATERIALIZED VIEW IF NOT EXISTS nyc_taxi_hourly_mv ON CLUSTER cloudkoffer\n",
    "    ENGINE = ReplicatedSummingMergeTree('/clickhouse/tables/{shard}/nyc_taxi_hourly_mv', '{replica}')\n",
    "    PARTITION BY toYYYYMM(hour)\n",
    "    ORDER BY (hour, PULocationID)\n",
    "    AS SELECT\n",
    "        toStartOfHour(tpep_pickup_datetime) AS hour,\n",
    "        PULocationID,\n",
    "        count()            AS trips,\n",
    "        sum(total_amount)  AS revenue,\n",
    "        sum(trip_distance) AS distance\n",
    "    FROM nyc_taxi\n",
    "    GROUP BY hour, PULocationID\n",
    "\"\"\")\n",
    "\n",
    "print('Materialized View nyc_taxi_hourly_mv erstellt (fuellt sich automatisch beim INSERT)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ClickHouse kann Parquet-Dateien direkt per URL laden!\n",
    "# Dies nutzt die eingebaute url()-Tabellenfunktion.\n",
    "\n",
    "PARQUET_URLS = [\n",
    "    ('Januar 2023',  'https://d37ci6vzurychx.cloudfront.net/trip-data/yellow_tripdata_2023-01.parquet'),\n",
    "    ('Februar 2023', 'https://d37ci6vzurychx.cloudfront.net/trip-data/yellow_tripdata_2023-02.parquet'),\n",
    "]\n",
    "\n",
    "INSERT_SQL = \"\"\"\n",
    "    INSERT INTO nyc_taxi\n",
    "    SELECT\n",
    "        VendorID,\n",
    "        tpep_pickup_datetime,\n",
    "        tpep_dropoff_datetime,\n",
    "        passenger_count,\n",
    "        trip_distance,\n",
    "        RatecodeID,\n",
    "        store_and_fwd_flag,\n",
    "        PULocationID,\n",
    "        DOLocationID,\n",
    "        payment_type,\n",
    "        fare_amount,\n",
    "        extra,\n",
    "        mta_tax,\n",
    "        tip_amount,\n",
    "        tolls_amount,\n",
    "        improvement_surcharge,\n",
    "        total_amount,\n",
    "        congestion_surcharge,\n",
    "        Airport_fee\n",
    "    FROM url('{url}', 'Parquet')\n",
    "\"\"\"\n",
    "\n",
    "row_count_before = client.command('SELECT count() FROM nyc_taxi')\n",
    "if row_count_before > 0:\n",
    "    print(f'Tabelle enthaelt bereits {row_count_before:,} Datensaetze - ueberspringe Import.')\n",
    "else:\n",
    "    print(f'Lade {len(PARQUET_URLS)} Monate NYC Taxi Daten...')\n",
    "    print('(ClickHouse laedt Parquet nativ per HTTP, kein Python-Transfer noetig)')\n",
    "    print()\n",
    "\n",
    "    start_time = time.time()\n",
    "    loaded_before = 0\n",
    "\n",
    "    for label, url in PARQUET_URLS:\n",
    "        print(f'{label}: {url}')\n",
    "        t0 = time.time()\n",
    "        client.command(INSERT_SQL.format(url=url))\n",
    "        row_count_now = client.command('SELECT count() FROM nyc_taxi')\n",
    "        loaded = row_count_now - loaded_before\n",
    "        loaded_before = row_count_now\n",
    "        print(f'  -> {loaded:,} Datensaetze in {time.time() - t0:.1f}s')\n",
    "\n",
    "    total_time = time.time() - start_time\n",
    "    total_rows = client.command('SELECT count() FROM nyc_taxi')\n",
    "\n",
    "    print(f'\\nGesamt: {total_rows:,} Datensaetze')\n",
    "    print(f'Ladezeit:   {total_time:.2f}s')\n",
    "    print(f'Throughput: {total_rows / total_time:,.0f} Zeilen/Sekunde')"
   ]
  },
