   "source": [
    "print('GESAMTSTATISTIKEN')\n",
    "print('=' * 60)\n",
    "\n",
    "start_time = time.time()\n",
    "result = client.query(\"\"\"\n",
    "    SELECT\n",
    "        count()                     AS total_trips,\n",
    "        sum(fare_amount)            AS total_fares,\n",
    "        sum(tip_amount)             AS total_tips,\n",
    "        sum(total_amount)           AS total_revenue,\n",
    "        avg(trip_distance)          AS avg_distance,\n",
    "        avg(fare_amount)            AS avg_fare,\n",
    "        avg(tip_amount)             AS avg_tip,\n",
    "        avg(total_amount)           AS avg_total,\n",
    "        avg(passenger_count)        AS avg_passengers,\n",
    "        sum(trip_distance)          AS total_distance\n",
    "    FROM nyc_taxi\n",
    "    WHERE trip_distance > 0\n",
    "      AND trip_distance < 100\n",
    "      AND fare_amount > 0\n",
    "      AND fare_amount < 500\n",
    "      AND passenger_count > 0\n",
    "      AND passenger_count <= 6\n",
    "\"\"\")\n",
    "query_time = time.time() - start_time\n",
    "row = result.result_rows[0]\n",
    "\n",
    "print(f'\\nAnzahl Fahrten:           {row[0]:>15,}')\n",
    "print(f'Gesamtdistanz:            {row[9]:>15,.0f} Meilen')\n",
    "print(f'Gesamtumsatz:             ${row[3]:>14,.2f}')\n",
    "print(f'  - Fahrpreise:           ${row[1]:>14,.2f}')\n",
    "print(f'  - Trinkgeld:            ${row[2]:>14,.2f}')\n",
    "print(f'\\nDurchschnittswerte pro Fahrt:')\n",
    "print(f'  - Distanz:              {row[4]:>15.2f} Meilen')\n",
    "print(f'  - Fahrpreis:            ${row[5]:>14.2f}')\n",
    "print(f'  - Trinkgeld:            ${row[6]:>14.2f}')\n",
    "print(f'  - Gesamtbetrag:         ${row[7]:>14.2f}')\n",
    "print(f'  - Passagiere:           {row[8]:>15.1f}')\n",
    "print(f'\\nQuery-Zeit: {query_time:.3f}s')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('FAHRTEN PRO WOCHENTAG')\n",
    "print('=' * 60)\n",
    "\n",
    "start_time = time.time()\n",
    "result = client.query(\"\"\"\n",
    "    SELECT\n",
    "        toDayOfWeek(tpep_pickup_datetime) AS weekday,\n",
    "        count()                           AS trips,\n",
    "        sum(total_amount)                 AS revenue,\n",
    "        avg(total_amount)                 AS avg_amount,\n",
    "        avg(trip_distance)                AS avg_distance,\n",
    "        avg(tip_amount)                   AS avg_tip\n",
    "    FROM nyc_taxi\n",
    "    WHERE trip_distance > 0 AND fare_amount > 0 AND passenger_count > 0\n",
    "    GROUP BY weekday\n",
    "    ORDER BY weekday\n",
    "\"\"\")\n",
    "query_time = time.time() - start_time\n",
    "\n",
    "weekdays = ['Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa', 'So']\n",
    "print(f'\\n{\"Tag\":>4} {\"Fahrten\":>12} {\"Umsatz\":>14} {\"Avg Betrag\":>10} {\"Avg Dist\":>10} {\"Avg Tip\":>8}')\n",
    "print('-' * 62)\n",
    "\n",
    "for row in result.result_rows:\n",
    "    day_name = weekdays[row[0] - 1]\n",
    "    print(f'{day_name:>4} {row[1]:>12,} ${row[2]:>12,.0f} ${row[3]:>9.2f} {row[4]:>9.2f}mi ${row[5]:>6.2f}')\n",
    "\n",
    "print(f'\\nQuery-Zeit: {query_time:.3f}s')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('FAHRTEN PRO STUNDE')\n",
    "print('=' * 60)\n",
    "\n",
    "start_time = time.time()\n",
    "result = client.query(\"\"\"\n",
    "    SELECT\n",
    "        toHour(tpep_pickup_datetime) AS hour,\n",
    "        count()                      AS trips,\n",
    "        sum(total_amount)            AS revenue,\n",
    "        avg(total_amount)            AS avg_amount\n",
    "    FROM nyc_taxi\n",
    "    WHERE trip_distance > 0 AND fare_amount > 0\n",
    "    GROUP BY hour\n",
    "    ORDER BY hour\n",
    "\"\"\")\n",
    "query_time = time.time() - start_time\n",
    "\n",
    "rows = result.result_rows\n",
    "max_trips = max(row[1] for row in rows)\n",
    "total_trips = sum(row[1] for row in rows)\n",
    "\n",
    "print(f'\\n{\"Stunde\":>6} {\"Fahrten\":>12} {\"Umsatz\":>14} {\"Avg\":>10}  Verteilung')\n",
    "print('-' * 70)\n",
    "\n",
    "for row in rows:\n",
    "    bar_len = int((row[1] / max_trips) * 20)\n",
    "    bar = chr(9608) * bar_len\n",
    "    pct = (row[1] / total_trips) * 100\n",
    "    print(f'{row[0]:>5}h {row[1]:>12,} ${row[2]:>12,.0f} ${row[3]:>9.2f}  {bar} ({pct:.1f}%)')\n",
    "\n",
    "print(f'\\nQuery-Zeit: {query_time:.3f}s')"
   ]
  },
  {
