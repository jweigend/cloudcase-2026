    "# Abfrage der Materialized View (wurde oben VOR dem Import erstellt)\n",
    "print('MATERIALIZED VIEW: Stundenaggregation')\n",
    "print('=' * 60)\n",
    "\n",
    "start_time = time.time()\n",
    "result = client.query(\"\"\"\n",
    "    SELECT\n",
    "        hour,\n",
    "        sum(trips)    AS total_trips,\n",
    "        sum(revenue)  AS total_revenue\n",
    "    FROM nyc_taxi_hourly_mv\n",
    "    GROUP BY hour\n",
    "    ORDER BY hour\n",
    "    LIMIT 24\n",
    "\"\"\")\n",
    "query_time = time.time() - start_time\n",
    "\n",
    "print(f'\\nErste 24 Stunden aus Materialized View:')\n",
    "print(f'{\"Stunde\":>20} {\"Fahrten\":>10} {\"Umsatz\":>14}')\n",
    "print('-' * 48)\n",
    "for row in result.result_rows:\n",
    "    print(f'{str(row[0]):>20} {row[1]:>10,} ${row[2]:>12,.2f}')\n",
    "\n",
    "print(f'\\nQuery-Zeit auf Materialized View: {query_time:.3f}s')\n",
    "print('(Deutlich schneller als Abfrage auf Rohdaten!)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('PERFORMANCE-VERGLEICH')\n",
    "print('=' * 60)\n",
    "print()\n",
    "\n",
    "queries = [\n",
    "    ('COUNT(*)',\n",
    "     'SELECT count() FROM nyc_taxi'),\n",
    "    ('SUM + AVG (Full Scan)',\n",
    "     'SELECT sum(total_amount), avg(trip_distance), avg(tip_amount) FROM nyc_taxi'),\n",
    "    ('GROUP BY Wochentag',\n",
    "     'SELECT toDayOfWeek(tpep_pickup_datetime) AS d, count(), avg(total_amount) FROM nyc_taxi GROUP BY d ORDER BY d'),\n",
    "    ('GROUP BY Stunde (24 Gruppen)',\n",
    "     'SELECT toHour(tpep_pickup_datetime) AS h, count(), sum(total_amount) FROM nyc_taxi GROUP BY h ORDER BY h'),\n",
    "    ('TOP 10 Locations',\n",
    "     'SELECT PULocationID, count() AS c FROM nyc_taxi GROUP BY PULocationID ORDER BY c DESC LIMIT 10'),\n",
    "    ('Zeitbereich-Filter (1 Woche)',\n",
    "     \"SELECT count(), avg(total_amount) FROM nyc_taxi WHERE tpep_pickup_datetime BETWEEN '2023-01-09' AND '2023-01-16'\"),\n",
    "    ('Cross-Month Filter (Jan+Feb)',\n",
    "     \"SELECT toYYYYMM(tpep_pickup_datetime) AS month, count(), sum(total_amount) FROM nyc_taxi GROUP BY month ORDER BY month\"),\n",
    "]\n",
    "\n",
    "print(f'{\"Query\":40s} {\"Zeit\":>10} {\"Zeilen/Sek\":>15}')\n",
    "print('-' * 68)\n",
    "\n",
    "row_count = client.command('SELECT count() FROM nyc_taxi')\n",
    "\n",
    "for name, sql in queries:\n",
    "    start = time.time()\n",
    "    client.query(sql)\n",
    "    elapsed = time.time() - start\n",
    "    throughput = row_count / elapsed\n",
    "    print(f'{name:40s} {elapsed:>9.3f}s {throughput:>14,.0f}')\n",
    "\n",
    "print()\n",
    "print('ClickHouse verarbeitet Millionen Zeilen in Millisekunden')\n",
    "print('dank spaltenorientierter Speicherung und Vektorisierung.')"
   ]
  },
