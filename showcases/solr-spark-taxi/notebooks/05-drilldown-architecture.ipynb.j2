        "from pyspark.sql import SparkSession\n",
        "from pyspark.sql import functions as F\n",
        "\n",
        "print('🚀 Starte Spark Session...')\n",
        "\n",
        "# Nutzt spark-defaults.conf: 6g Memory, 2 Cores pro Executor\n",
        "# → 5 Worker × 2 Executors × 2 Cores = 20 parallele Tasks\n",
        "spark = SparkSession.builder \\\n",
        "    .appName('Drill-Down Architecture - Parallel Import') \\\n",
        "    .master(SPARK_MASTER) \\\n",
        "    .getOrCreate()\n",
        "\n",
        "sc = spark.sparkContext\n",
        "print(f'✅ Spark Session gestartet')\n",
        "print(f'   Master: {sc.master}')\n",
        "print(f'   Default Parallelism: {sc.defaultParallelism}')"
      ]
