        "def execute_json_facet(query, facet, collection=COLLECTION):\n",
        "    \"\"\"\n",
        "    Führt eine Solr JSON Facet API Query aus.\n",
        "    Aggregiert pro Shard - skaliert mit Shard-Anzahl.\n",
        "    \"\"\"\n",
        "    url = f'http://{SOLR_HOST}:{SOLR_PORT}/solr/{collection}/query'\n",
        "    \n",
        "    start = time.time()\n",
        "    resp = requests.post(url, json={\n",
        "        'query': query,\n",
        "        'limit': 0,\n",
        "        'facet': facet\n",
        "    }, timeout=30)\n",
        "    elapsed_ms = (time.time() - start) * 1000\n",
        "    resp.raise_for_status()\n",
        "    \n",
        "    result = resp.json()\n",
        "    print(f'   ⏱️  Query-Zeit: {elapsed_ms:.0f}ms')\n",
        "    return result.get('facets', {})\n",
        "\n",
        "print('✅ JSON Facet API Helper geladen')"
