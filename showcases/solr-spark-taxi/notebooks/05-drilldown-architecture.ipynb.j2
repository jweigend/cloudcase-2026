        "    \n",
        "    # Zu Pandas für Anzeige\n",
        "    df_spark_routes = top_routes_spark.toPandas()\n",
        "    \n",
        "    spark_time = time.time() - start_spark_routes\n",
        "    print(f'\\n⏱️  Spark parallel ({len(get_shard_info(COLLECTION))} Shards): {spark_time:.2f}s')\n",
        "    display(df_spark_routes)\n",
        "    \n",
        "    # Vergleich\n",
