      "source": [
        "def solr_delete_all(collection):\n",
        "    \"\"\"Löscht alle Dokumente einer Collection.\"\"\"\n",
        "    url = f'http://{SOLR_HOST}:{SOLR_PORT}/solr/{collection}/update'\n",
        "    resp = requests.post(url, json={'delete': {'query': '*:*'}}, params={'commit': 'true'}, timeout=60)\n",
        "    resp.raise_for_status()\n",
        "    return resp.json()\n",
        "\n",
        "def import_parquet_to_solr_parallel(spark, parquet_path, collection, batch_size=2000):\n",
        "    \"\"\"\n",
        "    Hochparalleler Import: Spark liest Parquet optimal, Executors schreiben parallel nach SolrCloud.\n",
        "    \n",
        "    Datenfluss:\n",
        "      1. Spark liest Parquet mit optimiertem Reader (nutzt alle Row Groups parallel)\n",
        "      2. Repartition auf N Partitionen = Executors × Cores\n",
        "      3. Jeder Executor sendet per Round-Robin an einen Solr Node\n",
        "      4. SolrCloud routet Dokumente basierend auf ID zum richtigen Shard\n",
        "    \n",
        "    Hinweis: Die Executors muessen NICHT auf den Solr Nodes laufen.\n",
        "    SolrCloud uebernimmt das Routing - das System ist resilient.\n",
        "    \"\"\"\n",
        "    print(f'\\n📖 Lade {parquet_path}...')\n",
        "    start_time = time.time()\n",
        "    \n",
        "    # Parquet laden (Spark's optimierter Reader)\n",
        "    df = spark.read.parquet(parquet_path)\n",
        "    \n",
        "    # Spalten normalisieren\n",
        "    if 'Airport_fee' in df.columns:\n",
        "        df = df.withColumnRenamed('Airport_fee', 'airport_fee')\n",
        "    \n",
        "    # Datum-Spalten transformieren (VOR dem Push zu Executors)\n",
        "    df = df.withColumn('pickup_date', F.date_format('tpep_pickup_datetime', 'yyyy-MM-dd')) \\\n",
        "           .withColumn('pickup_hour', F.hour('tpep_pickup_datetime')) \\\n",
        "           .withColumn('pickup_dayofweek', F.dayofweek('tpep_pickup_datetime')) \\\n",
        "           .withColumn('tpep_pickup_datetime', F.date_format('tpep_pickup_datetime', \"yyyy-MM-dd'T'HH:mm:ss'Z'\")) \\\n",
        "           .withColumn('tpep_dropoff_datetime', F.date_format('tpep_dropoff_datetime', \"yyyy-MM-dd'T'HH:mm:ss'Z'\")) \\\n",
        "           .withColumn('id', F.expr('uuid()'))\n",
        "    \n",
        "    # Optimale Parallelität: 20 Partitionen für 5 Executors × 4 Cores\n",
        "    num_partitions = 20\n",
        "    df = df.repartition(num_partitions)\n",
        "    \n",
        "    total_rows = df.count()\n",
        "    print(f'   {total_rows:,} Zeilen in {time.time() - start_time:.1f}s')\n",
        "    print(f'   Partitionen: {num_partitions} (5 Executors × 4 Cores)')\n",
        "    \n",
        "    print(f'📤 Paralleler Push nach Solr {collection} (Round-Robin über {len(SOLR_NODES)} Nodes)...')\n",
        "    start_push = time.time()\n",
        "    \n",
        "    # Broadcast der Konfiguration\n",
        "    solr_port_bc = spark.sparkContext.broadcast(SOLR_PORT)\n",
        "    solr_nodes_bc = spark.sparkContext.broadcast(SOLR_NODES)\n",
        "    collection_bc = spark.sparkContext.broadcast(collection)\n",
        "    batch_size_bc = spark.sparkContext.broadcast(batch_size)\n",
        "    \n",
        "    def send_partition_to_solr(partition_index, iterator):\n",
        "        \"\"\"Sendet Partition an einen Solr Node (Round-Robin). SolrCloud routet zum richtigen Shard.\"\"\"\n",
        "        import requests\n",
        "        import socket\n",
        "        \n",
        "        port = solr_port_bc.value\n",
        "        nodes = solr_nodes_bc.value\n",
        "        coll = collection_bc.value\n",
        "        batch_sz = batch_size_bc.value\n",
        "        hostname = socket.gethostname()\n",
        "        \n",
        "        # Round-Robin: Partition → Solr Node (SolrCloud routet zum Shard)\n",
        "        target_node = nodes[partition_index % len(nodes)]\n",
        "        url = f'http://{target_node}:{port}/solr/{coll}/update'\n",
        "        \n",
        "        batch = []\n",
        "        count = 0\n",
        "        \n",
        "        for row in iterator:\n",
        "            doc = row.asDict()\n",
        "            # NaN handling (v != v ist True für NaN)\n",
        "            doc = {k: (None if v != v else v) for k, v in doc.items()}\n",
        "            batch.append(doc)\n",
        "            \n",
        "            if len(batch) >= batch_sz:\n",
        "                resp = requests.post(url, json=batch, timeout=60)\n",
        "                resp.raise_for_status()\n",
        "                count += len(batch)\n",
        "                batch = []\n",
        "        \n",
        "        if batch:\n",
        "            resp = requests.post(url, json=batch, timeout=60)\n",
        "            resp.raise_for_status()\n",
        "            count += len(batch)\n",
        "        \n",
        "        yield (partition_index, hostname, count, target_node)\n",
        "    \n",
        "    # Parallel auf allen Executors\n",
        "    results = df.rdd.mapPartitionsWithIndex(send_partition_to_solr).collect()\n",
        "    \n",
        "    # Commit\n",
        "    commit_url = f'http://{SOLR_HOST}:{SOLR_PORT}/solr/{collection}/update?commit=true'\n",
        "    requests.post(commit_url, json=[], timeout=30)\n",
        "    \n",
        "    elapsed = time.time() - start_push\n",
        "    total_sent = sum(r[2] for r in results)\n",
        "    \n",
        "    # Statistik nach Worker gruppieren\n",
        "    from collections import defaultdict\n",
        "    by_host = defaultdict(lambda: {'partitions': 0, 'docs': 0, 'targets': set()})\n",
        "    for _, hostname, count, target in results:\n",
        "        by_host[hostname]['partitions'] += 1\n",
        "        by_host[hostname]['docs'] += count\n",
        "        by_host[hostname]['targets'].add(target)\n",
        "    \n",
        "    print(f'   📊 Import-Statistik (Parallel Shard Access):')\n",
        "    for hostname in sorted(by_host.keys()):\n",
        "        stats = by_host[hostname]\n",
        "        targets = ', '.join(sorted(stats['targets']))\n",
        "        print(f'      {hostname}: {stats[\"partitions\"]:2d} Partitionen, {stats[\"docs\"]:,} docs → {targets} → SolrCloud routing')\n",
        "    \n",
        "    print(f'   ✅ {total_sent:,} Dokumente in {elapsed:.1f}s ({total_sent/elapsed:,.0f} docs/s)')\n",
        "    \n",
        "    return total_sent\n",
        "\n",
        "print('✅ Import-Funktionen definiert (Spark-optimiert, Round-Robin über SolrCloud Nodes)')"
      ]
    },
    {
