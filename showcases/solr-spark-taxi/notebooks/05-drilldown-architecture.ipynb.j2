        "            'fl': fields,\n",
        "            'wt': 'json'\n",
        "        }\n",
        "        \n",
        "        start = time.time()\n",
        "        resp = requests.get(f'{self.base_url}/select', params=params, timeout=30)\n",
        "        elapsed_ms = (time.time() - start) * 1000\n",
        "        \n",
        "        result = resp.json()\n",
