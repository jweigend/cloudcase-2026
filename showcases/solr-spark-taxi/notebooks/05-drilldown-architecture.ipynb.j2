        "        print(f'   Query-Zeit: {elapsed_ms:.0f}ms')\n",
        "        print(f'{\"─\" * 50}')\n",
        "        \n",
        "        return pd.DataFrame(result['response']['docs'])\n",
        "\n",
        "# Explorer initialisieren\n",
        "explorer = DrillDownExplorer(COLLECTION)\n",
        "print('✅ Drill-Down Explorer initialisiert')"
