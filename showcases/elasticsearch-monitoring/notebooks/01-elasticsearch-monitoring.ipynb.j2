{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Elasticsearch Monitoring Data Explorer\n",
        "\n",
        "Dieses Notebook zeigt die Analyse von Monitoring-Daten mit Elasticsearch:\n",
        "- Index erstellen mit Mapping\n",
        "- Monitoring-Events laden (Server-Metriken, Logs, Alerts)\n",
        "- Volltextsuche ueber Log-Messages\n",
        "- Aggregationen und Visualisierungen"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 1. Verbindung und Setup"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from elasticsearch import Elasticsearch, helpers\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from datetime import datetime, timedelta\n",
        "import random\n",
        "import json\n",
        "\n",
        "es = Elasticsearch(['http://node1.cloud.local:9200'])\n",
        "print(f'Connected to: {es.info()[\"cluster_name\"]} (v{es.info()[\"version\"][\"number\"]})')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2. Index mit Mapping erstellen"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "INDEX_NAME = 'monitoring-events'\n",
        "\n",
        "# Index loeschen falls vorhanden\n",
        "if es.indices.exists(index=INDEX_NAME):\n",
        "    es.indices.delete(index=INDEX_NAME)\n",
        "    print(f'Index {INDEX_NAME} geloescht.')\n",
        "\n",
        "# Mapping definieren\n",
        "mapping = {\n",
        "    'settings': {\n",
        "        'number_of_shards': 4,\n",
        "        'number_of_replicas': 1\n",
        "    },\n",
        "    'mappings': {\n",
        "        'properties': {\n",
        "            'timestamp':  { 'type': 'date' },\n",
        "            'host':       { 'type': 'keyword' },\n",
        "            'service':    { 'type': 'keyword' },\n",
        "            'event_type': { 'type': 'keyword' },\n",
        "            'severity':   { 'type': 'keyword' },\n",
        "            'message':    { 'type': 'text', 'analyzer': 'standard' },\n",
        "            'cpu_percent':    { 'type': 'float' },\n",
        "            'memory_percent': { 'type': 'float' },\n",
        "            'disk_percent':   { 'type': 'float' },\n",
        "            'response_time_ms': { 'type': 'integer' },\n",
        "            'status_code':  { 'type': 'integer' },\n",
        "            'bytes_sent':   { 'type': 'long' }\n",
        "        }\n",
        "    }\n",
        "}\n",
        "\n",
        "es.indices.create(index=INDEX_NAME, body=mapping)\n",
        "print(f'Index {INDEX_NAME} erstellt mit 4 Shards, 1 Replica.')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 3. Synthetische Monitoring-Daten generieren"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "HOSTS = ['web-server-01', 'web-server-02', 'api-server-01', 'db-server-01', 'cache-server-01']\n",
        "SERVICES = ['nginx', 'flask-api', 'postgresql', 'redis', 'prometheus', 'node-exporter']\n",
        "SEVERITIES = ['info', 'warning', 'error', 'critical']\n",
        "EVENT_TYPES = ['metric', 'log', 'alert']\n",
        "\n",
        "LOG_MESSAGES = [\n",
        "    'Request processed successfully in {rt}ms',\n",
        "    'Connection pool exhausted, waiting for available connection',\n",
        "    'Slow query detected: SELECT * FROM users WHERE last_login > now() - interval 30 day',\n",
        "    'Health check passed for upstream backend',\n",
        "    'SSL certificate will expire in 14 days',\n",
        "    'Rate limit exceeded for client IP 10.0.{a}.{b}',\n",
        "    'Disk usage warning: /data partition at {disk}% capacity',\n",
        "    'Out of memory: killed process {pid} (java)',\n",
        "    'Failed authentication attempt from 192.168.{a}.{b}',\n",
        "    'Backup completed successfully, {size}MB written',\n",
        "    'Database replication lag: {lag}s behind primary',\n",
        "    'Cache hit ratio dropped below threshold: {ratio}%',\n",
        "    'New deployment v2.{v}.{p} rolling out to production',\n",
        "    'Garbage collection pause: {gc}ms (G1 Young Generation)',\n",
        "    'TCP connection timeout to upstream {host}:{port}',\n",
        "]\n",
        "\n",
        "def generate_events(count=50000):\n",
        "    \"\"\"Generiert synthetische Monitoring-Events.\"\"\"\n",
        "    base_time = datetime.utcnow() - timedelta(hours=24)\n",
        "    \n",
        "    for i in range(count):\n",
        "        ts = base_time + timedelta(seconds=random.randint(0, 86400))\n",
        "        event_type = random.choice(EVENT_TYPES)\n",
        "        host = random.choice(HOSTS)\n",
        "        service = random.choice(SERVICES)\n",
        "        \n",
        "        # Severity-Verteilung: 70% info, 20% warning, 8% error, 2% critical\n",
        "        r = random.random()\n",
        "        if r < 0.70:\n",
        "            severity = 'info'\n",
        "        elif r < 0.90:\n",
        "            severity = 'warning'\n",
        "        elif r < 0.98:\n",
        "            severity = 'error'\n",
        "        else:\n",
        "            severity = 'critical'\n",
        "        \n",
        "        msg = random.choice(LOG_MESSAGES).format(\n",
        "            rt=random.randint(5, 2000),\n",
        "            a=random.randint(0, 255),\n",
        "            b=random.randint(0, 255),\n",
        "            disk=random.randint(50, 99),\n",
        "            pid=random.randint(1000, 9999),\n",
        "            size=random.randint(100, 5000),\n",
        "            lag=random.randint(1, 60),\n",
        "            ratio=random.randint(40, 95),\n",
        "            v=random.randint(1, 9),\n",
        "            p=random.randint(0, 99),\n",
        "            gc=random.randint(10, 500),\n",
        "            host=random.choice(HOSTS),\n",
        "            port=random.choice([5432, 6379, 8080, 9090]),\n",
        "        )\n",
        "        \n",
        "        doc = {\n",
        "            '_index': INDEX_NAME,\n",
        "            '_source': {\n",
        "                'timestamp': ts.isoformat(),\n",
        "                'host': host,\n",
        "                'service': service,\n",
        "                'event_type': event_type,\n",
        "                'severity': severity,\n",
        "                'message': msg,\n",
        "                'cpu_percent': round(random.uniform(5, 95), 1),\n",
        "                'memory_percent': round(random.uniform(20, 90), 1),\n",
        "                'disk_percent': round(random.uniform(30, 95), 1),\n",
        "                'response_time_ms': random.randint(1, 2000),\n",
        "                'status_code': random.choice([200, 200, 200, 201, 301, 400, 404, 500, 502, 503]),\n",
        "                'bytes_sent': random.randint(100, 1000000),\n",
        "            }\n",
        "        }\n",
        "        yield doc\n",
        "\n",
        "# Bulk-Import\n",
        "success, errors = helpers.bulk(es, generate_events(50000), chunk_size=5000, request_timeout=60)\n",
        "print(f'{success:,} Events geladen, {len(errors) if isinstance(errors, list) else errors} Fehler')\n",
        "\n",
        "# Refresh fuer sofortige Sichtbarkeit\n",
        "es.indices.refresh(index=INDEX_NAME)\n",
        "count = es.count(index=INDEX_NAME)['count']\n",
        "print(f'Index {INDEX_NAME}: {count:,} Dokumente')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 4. Volltextsuche"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Suche nach Log-Messages mit bestimmten Begriffen\n",
        "search_term = 'connection timeout'\n",
        "\n",
        "result = es.search(\n",
        "    index=INDEX_NAME,\n",
        "    body={\n",
        "        'query': {\n",
        "            'match': {\n",
        "                'message': search_term\n",
        "            }\n",
        "        },\n",
        "        'size': 10,\n",
        "        'sort': [{'timestamp': 'desc'}]\n",
        "    }\n",
        ")\n",
        "\n",
        "print(f'Suche: \"{search_term}\"')\n",
        "print(f'Treffer: {result[\"hits\"][\"total\"][\"value\"]:,}')\n",
        "print('=' * 80)\n",
        "for hit in result['hits']['hits']:\n",
        "    src = hit['_source']\n",
        "    print(f'[{src[\"timestamp\"][:19]}] [{src[\"severity\"]:8}] {src[\"host\"]:18} {src[\"message\"][:60]}')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 5. Aggregationen: Events nach Severity"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "result = es.search(\n",
        "    index=INDEX_NAME,\n",
        "    body={\n",
        "        'size': 0,\n",
        "        'aggs': {\n",
        "            'by_severity': {\n",
        "                'terms': { 'field': 'severity', 'size': 10 }\n",
        "            }\n",
        "        }\n",
        "    }\n",
        ")\n",
        "\n",
        "buckets = result['aggregations']['by_severity']['buckets']\n",
        "labels = [b['key'] for b in buckets]\n",
        "counts = [b['doc_count'] for b in buckets]\n",
        "\n",
        "colors = {'info': '#2ecc71', 'warning': '#f39c12', 'error': '#e74c3c', 'critical': '#8e44ad'}\n",
        "bar_colors = [colors.get(l, '#3498db') for l in labels]\n",
        "\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.bar(labels, counts, color=bar_colors)\n",
        "plt.title('Monitoring Events nach Severity')\n",
        "plt.ylabel('Anzahl Events')\n",
        "for i, (label, count) in enumerate(zip(labels, counts)):\n",
        "    plt.text(i, count + 200, f'{count:,}', ha='center', fontweight='bold')\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 6. Events pro Stunde (Date Histogram)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "result = es.search(\n",
        "    index=INDEX_NAME,\n",
        "    body={\n",
        "        'size': 0,\n",
        "        'aggs': {\n",
        "            'events_over_time': {\n",
        "                'date_histogram': {\n",
        "                    'field': 'timestamp',\n",
        "                    'fixed_interval': '1h'\n",
        "                },\n",
        "                'aggs': {\n",
        "                    'by_severity': {\n",
        "                        'terms': { 'field': 'severity' }\n",
        "                    }\n",
        "                }\n",
        "            }\n",
        "        }\n",
        "    }\n",
        ")\n",
        "\n",
        "buckets = result['aggregations']['events_over_time']['buckets']\n",
        "times = [b['key_as_string'][:13] for b in buckets]\n",
        "total = [b['doc_count'] for b in buckets]\n",
        "\n",
        "plt.figure(figsize=(14, 5))\n",
        "plt.bar(range(len(times)), total, color='#3498db', alpha=0.8)\n",
        "plt.title('Monitoring Events pro Stunde (letzte 24h)')\n",
        "plt.ylabel('Anzahl Events')\n",
        "plt.xlabel('Stunde')\n",
        "plt.xticks(range(0, len(times), max(1, len(times)//12)), \n",
        "           [times[i][-5:] for i in range(0, len(times), max(1, len(times)//12))],\n",
        "           rotation=45)\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 7. Top Hosts nach Error-Rate"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "result = es.search(\n",
        "    index=INDEX_NAME,\n",
        "    body={\n",
        "        'size': 0,\n",
        "        'aggs': {\n",
        "            'by_host': {\n",
        "                'terms': { 'field': 'host', 'size': 10 },\n",
        "                'aggs': {\n",
        "                    'errors': {\n",
        "                        'filter': {\n",
        "                            'terms': { 'severity': ['error', 'critical'] }\n",
        "                        }\n",
        "                    },\n",
        "                    'avg_cpu': {\n",
        "                        'avg': { 'field': 'cpu_percent' }\n",
        "                    },\n",
        "                    'avg_memory': {\n",
        "                        'avg': { 'field': 'memory_percent' }\n",
        "                    }\n",
        "                }\n",
        "            }\n",
        "        }\n",
        "    }\n",
        ")\n",
        "\n",
        "print('Host-Uebersicht')\n",
        "print('=' * 75)\n",
        "print(f'{\"Host\":20} {\"Events\":>8} {\"Errors\":>8} {\"Error%\":>8} {\"Avg CPU\":>8} {\"Avg Mem\":>8}')\n",
        "print('-' * 75)\n",
        "for b in result['aggregations']['by_host']['buckets']:\n",
        "    err_pct = (b['errors']['doc_count'] / b['doc_count'] * 100) if b['doc_count'] > 0 else 0\n",
        "    print(f'{b[\"key\"]:20} {b[\"doc_count\"]:>8,} {b[\"errors\"][\"doc_count\"]:>8,} {err_pct:>7.1f}% {b[\"avg_cpu\"][\"value\"]:>7.1f}% {b[\"avg_memory\"][\"value\"]:>7.1f}%')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 8. Response-Time-Verteilung (Percentile)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "result = es.search(\n",
        "    index=INDEX_NAME,\n",
        "    body={\n",
        "        'size': 0,\n",
        "        'aggs': {\n",
        "            'rt_percentiles': {\n",
        "                'percentiles': {\n",
        "                    'field': 'response_time_ms',\n",
        "                    'percents': [50, 75, 90, 95, 99]\n",
        "                }\n",
        "            },\n",
        "            'rt_histogram': {\n",
        "                'histogram': {\n",
        "                    'field': 'response_time_ms',\n",
        "                    'interval': 100,\n",
        "                    'min_doc_count': 1\n",
        "                }\n",
        "            }\n",
        "        }\n",
        "    }\n",
        ")\n",
        "\n",
        "# Percentiles\n",
        "pcts = result['aggregations']['rt_percentiles']['values']\n",
        "print('Response Time Percentiles:')\n",
        "print('=' * 30)\n",
        "for k, v in pcts.items():\n",
        "    print(f'  p{k}: {v:.0f}ms')\n",
        "\n",
        "# Histogram\n",
        "hist_buckets = result['aggregations']['rt_histogram']['buckets']\n",
        "bins = [b['key'] for b in hist_buckets]\n",
        "counts = [b['doc_count'] for b in hist_buckets]\n",
        "\n",
        "plt.figure(figsize=(12, 5))\n",
        "plt.bar(bins, counts, width=80, color='#e74c3c', alpha=0.7)\n",
        "plt.title('Response Time Verteilung')\n",
        "plt.xlabel('Response Time (ms)')\n",
        "plt.ylabel('Anzahl Events')\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 9. Cluster-Statistiken"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "stats = es.indices.stats(index=INDEX_NAME)\n",
        "total = stats['_all']['total']\n",
        "\n",
        "print('Index-Statistiken')\n",
        "print('=' * 40)\n",
        "print(f'Dokumente:     {total[\"docs\"][\"count\"]:>12,}')\n",
        "print(f'Store Size:    {total[\"store\"][\"size_in_bytes\"] / 1024 / 1024:>11.1f} MB')\n",
        "print(f'Indexing:      {total[\"indexing\"][\"index_total\"]:>12,} ops')\n",
        "print(f'Search:        {total[\"search\"][\"query_total\"]:>12,} queries')\n",
        "print(f'Search Time:   {total[\"search\"][\"query_time_in_millis\"]:>12,} ms')"
      ]
    },
    {
