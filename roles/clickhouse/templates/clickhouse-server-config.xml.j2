<clickhouse>
    <!-- Listen on all interfaces -->
    <listen_host>0.0.0.0</listen_host>

    <!-- Data path -->
    <path>{{ clickhouse_data_dir }}/</path>
    <tmp_path>{{ clickhouse_data_dir }}/tmp/</tmp_path>

    <!-- Logging -->
    <logger>
        <level>information</level>
        <log>{{ clickhouse_log_dir }}/clickhouse-server.log</log>
        <errorlog>{{ clickhouse_log_dir }}/clickhouse-server.err.log</errorlog>
        <size>100M</size>
        <count>3</count>
    </logger>

    <!-- Ports -->
    <http_port>{{ clickhouse_http_port }}</http_port>
    <tcp_port>{{ clickhouse_native_port }}</tcp_port>
    <interserver_http_port>{{ clickhouse_interserver_port }}</interserver_http_port>

    <!-- Prometheus metrics endpoint -->
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>{{ clickhouse_metrics_port }}</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
    </prometheus>

    <!-- Cluster definition: 1 Shard, {{ groups['clickhouse_server'] | length }} Replicas -->
    <remote_servers>
        <{{ clickhouse_cluster_name }}>
            <shard>
                <internal_replication>true</internal_replication>
{% for host in groups['clickhouse_server'] | sort %}
                <replica>
                    <host>{{ host }}.{{ domain }}</host>
                    <port>{{ clickhouse_native_port }}</port>
                </replica>
{% endfor %}
            </shard>
        </{{ clickhouse_cluster_name }}>
    </remote_servers>

    <!-- Macros for ReplicatedMergeTree -->
    <macros>
        <cluster>{{ clickhouse_cluster_name }}</cluster>
        <shard>1</shard>
        <replica>{{ inventory_hostname }}</replica>
    </macros>

    <!-- Use ClickHouse Keeper for coordination -->
    <zookeeper>
{% for host in groups['clickhouse_keeper'] | sort %}
        <node>
            <host>{{ host }}.{{ domain }}</host>
            <port>{{ clickhouse_keeper_port }}</port>
        </node>
{% endfor %}
    </zookeeper>

    <!-- Memory limits -->
    <max_server_memory_usage_to_ram_ratio>{{ clickhouse_max_memory_usage_ratio }}</max_server_memory_usage_to_ram_ratio>
</clickhouse>
