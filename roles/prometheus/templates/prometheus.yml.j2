global:
  scrape_interval: 15s
  evaluation_interval: 15s
  scrape_timeout: 10s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node'
    static_configs:
      - targets:
{% for host in groups['all'] | sort %}
          - '{{ host }}.{{ domain }}:9100'
{% endfor %}

  # Showcase-spezifische Targets via file_sd_configs
  - job_name: 'showcase'
    file_sd_configs:
      - files:
          - '{{ prometheus_home }}/targets.d/*.yml'
        refresh_interval: 30s
